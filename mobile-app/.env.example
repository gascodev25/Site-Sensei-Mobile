# Copy this file to .env and set the URL to your deployed backend.
# Expo exposes env vars prefixed with EXPO_PUBLIC_ to the client bundle at build time.
#
# For local development (from a physical device on same network), use your machine's LAN IP:
# EXPO_PUBLIC_API_BASE_URL=http://192.168.1.x:5000
# For production:
# EXPO_PUBLIC_API_BASE_URL=https://your-deployed-app.replit.app
EXPO_PUBLIC_API_BASE_URL=http://localhost:5000
