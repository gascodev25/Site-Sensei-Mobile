{
  "expo": {
    "name": "ACGWorks Field",
    "slug": "site-sensei-mobile",
    "version": "1.0.2",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#1e40af"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#1e40af"
      },
      "package": "digital.gasco.acgworks.field",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "versionCode": 3,
      "targetSdkVersion": 35,
      "compileSdkVersion": 35,
      "minSdkVersion": 21
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow ACGWorks Field to access your camera for capturing job site photos."
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "eas": {
        "projectId": "b34c69e0-ddc3-449e-b21d-a954220afb09"
      }
    },
    "owner": "gbgreen"
  }
}
